{
  "name": "@trip-loom/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/lib/auth.ts",
    "./env": "./src/env.d.ts",
    "./enums": "./src/enums.ts",
    "./dto": "./src/dto/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "cd ../.. && pnpm db:up && cd packages/api && dotenv -e ../../apps/web/.env -- tsx scripts/run-tests.ts",
    "db:generate": "dotenv -e ../../apps/web/.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../apps/web/.env -- drizzle-kit migrate",
    "db:studio": "dotenv -e ../../apps/web/.env -- drizzle-kit studio",
    "db:seed": "dotenv -e ../../apps/web/.env -- tsx seeds/seed.ts",
    "stripe:listen": "stripe listen --forward-to localhost:3000/api/webhooks/stripe",
    "seed:build-cities": "tsx seeds/generators/destinations/build-master-cities.ts",
    "seed:enrich-destinations": "tsx seeds/generators/destinations/enrich.ts",
    "seed:search-hotels": "tsx seeds/generators/hotels/search.ts",
    "seed:enrich-hotels": "tsx seeds/generators/hotels/enrich.ts",
    "seed:transform-hotels": "tsx seeds/generators/hotels/transform.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.212.0",
    "better-auth": "^1.4.18",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.2.25",
    "nanoid": "^5.1.5",
    "nodemailer": "^8.0.1",
    "pg": "^8.16.0",
    "server-only": "^0.0.1",
    "stripe": "^20.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.15.4",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.3"
  }
}

{
  "name": "@trip-loom/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./auth": "./src/lib/auth.ts",
    "./env": "./src/env.d.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "db:generate": "dotenv -e ../../apps/web/.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../apps/web/.env -- drizzle-kit migrate",
    "db:push": "dotenv -e ../../apps/web/.env -- drizzle-kit push",
    "db:studio": "dotenv -e ../../apps/web/.env -- drizzle-kit studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/eden": "^1.2.0",
    "better-auth": "^1.4.18",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.2.25",
    "postgres": "^3.4.8",
    "server-only": "^0.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@types/node": "^20.19.33",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.7.0"
  }
}

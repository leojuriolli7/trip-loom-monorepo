{
  "name": "@trip-loom/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./auth": "./src/lib/auth.ts",
    "./env": "./src/env.d.ts",
    "./dto": "./src/dto/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "cd ../.. && pnpm db:up && pnpm db:push && cd packages/api && dotenv -e ../../apps/web/.env -- vitest run",
    "db:generate": "dotenv -e ../../apps/web/.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../apps/web/.env -- drizzle-kit migrate",
    "db:push": "dotenv -e ../../apps/web/.env -- drizzle-kit push",
    "db:studio": "dotenv -e ../../apps/web/.env -- drizzle-kit studio",
    "db:seed": "dotenv -e ../../apps/web/.env -- tsx seeds/seed.ts",
    "data:populate:destinations": "tsx seeds/scripts/generate-destinations-from-geonames.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "better-auth": "^1.4.18",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.2.25",
    "nanoid": "^5.1.5",
    "postgres": "^3.4.8",
    "server-only": "^0.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.4",
    "typescript": "^5.7.0",
    "vitest": "^3.2.3"
  }
}

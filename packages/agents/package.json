{
  "name": "@trip-loom/agents",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./env": "./src/env.d.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "eval": "vitest --config vitest.eval.config.ts",
    "eval:run": "vitest run --config vitest.eval.config.ts",
    "eval:ci": "vitest run --config vitest.eval.config.ts --reporter=vitest-evals/reporter --reporter=json --outputFile.json=eval-results.json"
  },
  "dependencies": {
    "@arizeai/openinference-instrumentation-langchain": "^4.0.6",
    "@langchain/core": "^1.1.29",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.1",
    "@langchain/langgraph-sdk": "^1.6.5",
    "@langchain/langgraph-supervisor": "^1.0.1",
    "@langchain/mcp-adapters": "^1.1.3",
    "@langchain/openai": "^1.2.11",
    "@trip-loom/contracts": "workspace:*",
    "evlog": "^2.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "bun-types": "^1.3.10",
    "dotenv": "^17.3.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "vitest-evals": "^0.6.0"
  }
}

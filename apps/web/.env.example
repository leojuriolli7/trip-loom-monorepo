# Next.js (Client-side)

NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Backend API (@trip-loom/api)
# These are required for the API routes to work

# PostgreSQL connection string (matches docker-compose.yml for local dev)
DATABASE_URL=postgresql://triploom:triploom@localhost:5432/triploom

# Better Auth secret - generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here-minimum-32-characters

# API base URL
API_BASE_URL=http://localhost:3000

# Stripe (backend)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe (frontend)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Production only
# TRUSTED_ORIGINS=https://yourdomain.com
# CORS_ORIGINS=https://yourdomain.com

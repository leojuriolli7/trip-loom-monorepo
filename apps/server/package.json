{
  "name": "server",
  "private": true,
  "scripts": {
    "dev": "bun --watch --preload ./src/instrumentation.ts ./src/index.ts",
    "dev:stripe": "stripe listen --forward-to localhost:3001/api/webhooks/stripe",
    "build": "bun build src/index.ts src/instrumentation.ts --target bun --outdir dist",
    "start": "NODE_ENV=production bun --preload ./dist/instrumentation.js ./dist/index.js"
  },
  "dependencies": {
    "@opentelemetry/instrumentation-pg": "^0.58.3",
    "@trip-loom/api": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "^1.2.8"
  }
}

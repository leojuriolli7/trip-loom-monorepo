# PostgreSQL connection string (matches docker-compose.yml for local dev)
DATABASE_URL=postgresql://triploom:triploom@localhost:5432/triploom

# Better Auth secret - generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here-minimum-32-characters

# API base URL (used by Better Auth for route matching)
API_BASE_URL=http://localhost:3001

# Stripe (backend)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@triploom.com

# Base URLs for email links
# Verification email points to the API auth endpoint
VERIFY_EMAIL_BASE_URL=http://localhost:3001
# Forgot password email points to the frontend page
FORGOT_PASSWORD_EMAIL_BASE_URL=http://localhost:3000

# Website base URL for MCP server
FRONTEND_BASE_URL=http://localhost:3000

# OpenTelemetry + logs (optional)
# Local API defaults:
OTEL_SERVICE_NAME=trip-loom-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# MCP Server URL
# MCP_SERVER_URL=http://localhost:3002/mcp

# Weather provider (optional)
# OPEN_METEO_BASE_URL=https://api.open-meteo.com
# OPEN_METEO_GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com
# WEATHER_REQUEST_TIMEOUT_MS=8000

# Google Maps provider (optional, required for places search/details)
# GOOGLE_MAPS_API_KEY=your-google-maps-api-key
# GOOGLE_MAPS_TIMEOUT_MS=8000

# Production only (MCP URL, web app URL)
# TRUSTED_ORIGINS=https://yourdomain.com
# CORS_ORIGINS=https://yourdomain.com

# Agents models (OpenAI models) (Optional, defaults to GPT 5.2)
SUPERVISOR_MODEL=
DESTINATION_AGENT_MODEL=
FLIGHT_AGENT_MODEL=
HOTEL_AGENT_MODEL=
ITINERARY_AGENT_MODEL=
SUGGESTIONS_MODEL=

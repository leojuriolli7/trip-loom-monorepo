{
  "name": "trip-loom-monorepo",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:server": "pnpm --filter server dev",
    "dev:stripe": "pnpm --filter server dev:stripe",
    "dev:mcp": "pnpm --filter mcp-server dev",
    "build:web": "pnpm --filter web build",
    "build:server": "pnpm --filter server build",
    "build:mcp": "pnpm --filter mcp-server build",
    "start:web": "pnpm --filter web start",
    "start:server": "pnpm --filter server start",
    "start:mcp": "pnpm --filter mcp-server start",
    "lint:web": "pnpm --filter web lint",
    "typecheck:web": "pnpm --filter web typecheck",
    "typecheck:api": "pnpm --filter @trip-loom/api typecheck",
    "typecheck:mcp": "pnpm --filter mcp-server typecheck",
    "typecheck:agents": "pnpm --filter @trip-loom/agents typecheck",
    "test:e2e": "pnpm --filter web test:e2e",
    "test:e2e:ui": "pnpm --filter web test:e2e:ui",
    "test:api": "pnpm --filter @trip-loom/api test",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "docker:up": "docker compose --profile signoz up -d && open http://localhost:8080",
    "docker:down": "docker compose --profile signoz down",
    "db:generate": "pnpm --filter @trip-loom/api db:generate",
    "db:migrate": "pnpm --filter @trip-loom/api db:migrate",
    "db:studio": "pnpm --filter @trip-loom/api db:studio --port 6969"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  }
}
